# camofox-browser.env.example — copy to camofox-browser.env and set real values.
# Referenced by compose.example.yaml's camofox-browser service. NEVER commit the real file.

# Bearer token the REST API requires (this becomes CFX_KEY for the skill's drivers).
# Generate a long random string, e.g.: openssl rand -hex 32
CAMOFOX_ACCESS_KEY=replace-with-a-long-random-secret

# noVNC — set both to make the web VNC UI reachable (else it binds loopback-only inside the
# container). Leave VNC_BIND unset/127.0.0.1 to keep VNC disabled.
VNC_BIND=0.0.0.0
VNC_PASSWORD=replace-with-a-vnc-password
